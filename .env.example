# ==========================================
# VARIÁVEIS DE AMBIENTE - EXEMPLO
# ==========================================
# Copie este arquivo para .env e preencha com seus valores

# ==========================================
# DATABASE (Obrigatório)
# ==========================================
DATABASE_URL="mysql://root:root@localhost:3306/qualicontrol"

# ==========================================
# JWT & SEGURANÇA (Obrigatório)
# ==========================================
JWT_SECRET="seu-secret-aleatorio-muito-longo-e-seguro-minimo-32-caracteres"

# ==========================================
# MANU.IA OAUTH (Obrigatório para autenticação)
# ==========================================
# Obtenha estes valores em: https://console.manus.space
VITE_APP_ID="seu-app-id-aqui"
OAUTH_SERVER_URL="https://id.manus.space"
OWNER_OPEN_ID="seu-owner-open-id-aqui"

# ==========================================
# FORGE API (Opcional - só se usar IA)
# ==========================================
BUILT_IN_FORGE_API_URL="https://api.forge.manus.space"
BUILT_IN_FORGE_API_KEY="sua-api-key-aqui"

# ==========================================
# SERVIDOR (Opcional)
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# NOTAS:
# ==========================================
# 1. NÃO commite este arquivo com valores reais em git
# 2. .env está em .gitignore por segurança
# 3. Para development, valores genéricos funcionam
# 4. Para production, use valores seguros
# 5. JWT_SECRET mínimo 32 caracteres recomendado
